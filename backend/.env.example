# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=artifact_comparator
DB_USER=postgres
DB_PASSWORD=password

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-here

# OpenAI Configuration
# For development: use mock_key_for_development to use mock client (no API costs)
# For production: use your real OpenAI API key (sk-...)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_DEFAULT_MODEL=gpt-4.1-nano
OPENAI_FALLBACK_MODEL=gpt-4.1-nano
OPENAI_MAX_TOKENS=800
OPENAI_TEMPERATURE=0.7
OPENAI_THRESHOLD_LINES=500

# Email Configuration (Zoho Mail SMTP)
EMAIL_USER=your_email@zohomail.eu
EMAIL_PASSWORD=your_email_password_here
EMAIL_FROM_NAME=RitHub Verification
