# ============================================
# RitHub — Root Environment Variables
# ============================================
# This file is loaded by docker-compose (env_file: .env).
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================

# ----- Database Password -----
# DB_PASSWORD (used by backend) and POSTGRES_PASSWORD (used by the postgres
# container) MUST be the same value — they are two names for the same password.
DB_PASSWORD=change_me_in_production
POSTGRES_PASSWORD=change_me_in_production

# ----- Other Secrets -----
JWT_SECRET=change_me_to_a_random_string
EMAIL_USER=your_email@zohomail.eu
EMAIL_PASSWORD=your_email_password_here

# ----- Admin Seed Credentials -----
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@rithub.com
ADMIN_PASSWORD=change_me_in_production

# ----- OpenAI Configuration -----
OPENAI_API_KEY=your_openai_api_key_here
